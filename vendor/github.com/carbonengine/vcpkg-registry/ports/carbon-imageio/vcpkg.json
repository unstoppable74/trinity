{
  "name": "carbon-imageio",
  "version": "2.0.6",
  "port-version": 1,
  "description": "Image IO tools for Carbon.",
  "dependencies": [
    {
      "name": "carbon-core",
      "version>=": "2.4.0"
    },
    {
      "name": "ccp-debug-info",
      "host": true,
      "version>=": "1.0.2"
    },
    {
      "name": "gtest",
      "host": true,
      "version>=": "1.16.0"
    },
    {
      "name": "libjpeg-turbo",
      "version>=": "2.1.2"
    },
    {
      "name": "libpng",
      "version>=": "1.6.47"
    },
    {
      "name": "openvdb",
      "default-features": false,
      "features": [
        "nanovdb-nocuda"
      ],
      "version>=": "10.0.0#1"
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "zlib-ng",
      "version>=": "2.2.5"
    }
  ],
  "overrides": [
    {
      "name": "openexr",
      "version": "3.2.4"
    }
  ]
}
