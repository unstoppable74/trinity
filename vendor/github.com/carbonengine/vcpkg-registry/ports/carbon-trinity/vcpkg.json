{
  "name": "carbon-trinity",
  "version": "4.0.2",
  "description": "Graphics engine for the carbon game engine",
  "dependencies": [
    {
      "name": "amd-fidelityfx-cacao",
      "version>=": "1.2"
    },
    {
      "name": "amd-fidelityfx-cas",
      "version>=": "1.0"
    },
    {
      "name": "carbon-blue",
      "version>=": "5.1.2"
    },
    {
      "name": "carbon-core",
      "version>=": "2.4.0"
    },
    {
      "name": "carbon-imageio",
      "version>=": "2.0.6#1"
    },
    {
      "name": "carbon-math",
      "version>=": "1.2.1"
    },
    {
      "name": "carbon-mesh",
      "version>=": "1.0.1"
    },
    {
      "name": "carbon-parser",
      "version>=": "1.0.2"
    },
    {
      "name": "carbon-pdmprotowrapper",
      "version>=": "2.0.4"
    },
    {
      "name": "carbon-trinityaudioapi",
      "version>=": "2.0.3"
    },
    {
      "name": "ccp-debug-info",
      "host": true,
      "version>=": "1.0.1"
    },
    {
      "name": "freetype",
      "version>=": "2.13.3"
    },
    {
      "name": "gtest",
      "host": true,
      "version>=": "1.16.0"
    },
    {
      "name": "libjpeg-turbo",
      "version>=": "2.1.2"
    },
    {
      "name": "libpng",
      "version>=": "1.6.37"
    },
    {
      "name": "libsquish",
      "version>=": "1.15"
    },
    {
      "name": "tbb",
      "version>=": "2021.5.0#1"
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "vulkan-headers",
      "version>=": "1.4.304.1#1"
    },
    {
      "name": "vulkan-memory-allocator",
      "version>=": "3.0.1"
    },
    {
      "name": "zlib-ng",
      "version>=": "2.2.5"
    }
  ],
  "features": {
    "dx11": {
      "description": "Create DirectX 11 targets",
      "supports": "windows & x64",
      "dependencies": [
        {
          "name": "amd-fidelityfx-fsr",
          "version>=": "1.0.2"
        },
        {
          "name": "directx-dxc",
          "version>=": "2023-03-01#2"
        },
        {
          "name": "fxc",
          "version>=": "10.1"
        },
        {
          "name": "nvidia-aftermath",
          "version>=": "2021.1.0"
        },
        {
          "name": "nvidia-streamline",
          "features": [
            "dlss-fg",
            "dlss-sr",
            "nis"
          ],
          "version>=": "2.8.0"
        }
      ]
    },
    "dx12": {
      "description": "Create DirectX 12 targets",
      "supports": "windows & x64",
      "dependencies": [
        {
          "name": "amd-fidelityfx",
          "version>=": "1.1.4"
        },
        {
          "name": "amd-fidelityfx-fsr",
          "version>=": "1.0.2"
        },
        {
          "name": "directx-dxc",
          "version>=": "2023-03-01#2"
        },
        {
          "name": "fxc",
          "version>=": "10.1"
        },
        {
          "name": "intel-xess",
          "version>=": "2.0.1"
        },
        {
          "name": "nvidia-aftermath",
          "version>=": "2021.1.0"
        },
        {
          "name": "nvidia-streamline",
          "features": [
            "dlss-fg",
            "dlss-sr",
            "nis",
            "reflex"
          ],
          "version>=": "2.8.0"
        }
      ]
    },
    "metal": {
      "description": "Create Metal targets",
      "supports": "osx",
      "dependencies": [
        {
          "name": "amd-fidelityfx-fsr",
          "version>=": "1.0.2"
        }
      ]
    },
    "shader-compiler": {
      "description": "Shader compiler for carbon-trinity",
      "supports": "(windows & x64) | osx",
      "dependencies": [
        {
          "name": "directx-dxc",
          "platform": "windows & x64",
          "version>=": "2023-03-01#2"
        },
        {
          "name": "lemon-parser-generator",
          "host": true,
          "version>=": "3.39.3#1"
        },
        {
          "name": "re2c",
          "host": true,
          "version>=": "2.2"
        }
      ]
    },
    "with-granny": {
      "description": "Include Granny support",
      "dependencies": [
        {
          "name": "granny",
          "version>=": "2.12.0.14"
        }
      ]
    }
  }
}
