{
  "name": "carbon-mesh",
  "version": "1.0.1",
  "description": "Library that handles serialization of 3D mesh, skeleton and animation data. It also provides basic animation runtime support.",
  "dependencies": [
    {
      "name": "carbon-math",
      "version>=": "1.2.1"
    },
    {
      "name": "ccp-debug-info",
      "host": true,
      "version>=": "1.0.1"
    },
    {
      "name": "gtest",
      "version>=": "1.16.0"
    },
    {
      "name": "meshoptimizer",
      "version>=": "0.25"
    },
    {
      "name": "mikktspace",
      "version>=": "2020-10-06#3"
    },
    {
      "name": "python3",
      "version>=": "3.12.9"
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "simplygon": {
      "description": "Use Simplygon for LOD generation",
      "dependencies": [
        {
          "name": "simplygon",
          "version>=": "10.4.338#2"
        }
      ]
    },
    "tools": {
      "description": "Build tools",
      "dependencies": [
        "cli11",
        {
          "name": "glfw3",
          "version>=": "3.4#1"
        },
        "hash-library",
        {
          "name": "imgui",
          "features": [
            "glfw-binding",
            "vulkan-binding"
          ],
          "version>=": "1.91.9"
        },
        {
          "name": "nlohmann-json",
          "version>=": "3.12.0"
        },
        {
          "name": "shaderc",
          "version>=": "2025.2#1"
        },
        {
          "name": "tinyfiledialogs",
          "version>=": "3.19.1"
        },
        {
          "name": "vulkan",
          "version>=": "2023-12-17"
        }
      ]
    }
  },
  "overrides": [
    {
      "name": "cli11",
      "version": "2.4.2"
    }
  ]
}
