+    def test_stats(self):
+        expected_stats_per_module = {
+            'BytesReceived': len(MSG) * 2,
+            'BytesSent': len(MSG) * 2,
+            'PacketsReceived': 0,
+            'PacketsSent': 0,
+        }
+        stats = socket.getstats()
+        self.cli.send(MSG)
+        self.serv.recv(1024)
+        self.serv.send(MSG)
+        self.cli.recv(1024)
+        new_stats = socket.getstats()
