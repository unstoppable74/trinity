+    def test_recvpacket_async(self):
+        numPackets = 10
+        headerSize = 4
+        expected_stats_per_module = {
+            'BytesReceived': (len(MSG) + headerSize) * numPackets,
+            'BytesSent': (len(MSG) + headerSize) * numPackets,
