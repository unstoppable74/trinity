  "features": {
    "shader-compiler": {
      "description": "Shader compiler for carbon-trinity",
      "supports": "(windows & x64) | osx",
      "dependencies": [
        {
          "name": "re2c",
          "version>=": "2.2",
          "host": true
        },
        {
          "name": "lemon-parser-generator",
          "version>=": "3.39.3#1",
          "host": true
        },
        {
          "name": "directx-dxc",
          "version>=": "2023-03-01#2",
          "platform": "windows & x64"
        }
      ]
    },
    "dx11": {
      "description": "Create DirectX 11 targets",
       "supports": "windows & x64",
      "dependencies": [
        {
          "name": "directx-dxc",
          "version>=": "2023-03-01#2"
        },
        {
          "name": "fxc",
          "version>=": "10.1"
        },
        {
          "name": "amd-fidelityfx-fsr",
          "version>=": "1.0.2"
        },
        {
          "name": "nvidia-aftermath",
          "version>=": "2021.1.0"
        },
        {
          "name": "nvidia-streamline",
          "version>=": "2.8.0",
          "features":["dlss-fg","dlss-sr","nis" ]
        }
      ]
    },
    "dx12": {
      "description": "Create DirectX 12 targets",
      "supports": "windows & x64",
      "dependencies": [
        {
          "name": "directx-dxc",
          "version>=": "2023-03-01#2"
        },
        {
          "name": "fxc",
          "version>=": "10.1"
        },
        {
          "name": "amd-fidelityfx-fsr",
          "version>=": "1.0.2"
        },
        {
          "name": "amd-fidelityfx",
          "version>=": "1.1.4"
        },
        {
          "name": "nvidia-aftermath",
          "version>=": "2021.1.0"
        },
        {
          "name": "nvidia-streamline",
          "version>=": "2.8.0",
          "features":["dlss-fg","dlss-sr","nis","reflex" ]
        },
        {
          "name": "intel-xess",
          "version>=": "2.0.1"
        }
      ]
    },
    "metal": {
      "description": "Create Metal targets",
      "supports": "osx",
      "dependencies": [
        {
          "name": "amd-fidelityfx-fsr",
          "version>=": "1.0.2"
        }
      ]
    },
    "with-granny": {
      "description": "Include Granny support",
      "dependencies": [
        {
          "name": "granny",
          "version>=": "2.12.0.14"
        }
      ]
    }
